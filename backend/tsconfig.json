{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src"]
}