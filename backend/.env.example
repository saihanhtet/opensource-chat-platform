# API server port (Express). Default 3000 — Next.js dev runs on 5173 (see frontend/package.json).
PORT=3000

MONGODB_URI=mongodb://localhost:27017/chatapp
NODE_ENV=development
JWT_SECRET=change-me-use-long-random-string

# Resend (optional)
RESEND_API=
SENDER_EMAIL=onboarding@resend.dev
SENDER_NAME=opensource-chat-app

# Browser URL of the Next.js app (emails, cookie context). Matches `next dev -p 5173`.
CLIENT_URL=http://localhost:5173

# Cloudinary (optional)
CLOUD_NAME=
CLOUD_API=
CLOUD_SECRET=
